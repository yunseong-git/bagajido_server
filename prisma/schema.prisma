generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  oauth_provider   String   @db.VarChar(32)
  oauth_subject    String   @db.VarChar(255)
  email            String?  @db.VarChar(320)
  display_name     String?  @db.VarChar(100)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  stores_owned Store[]  @relation("StoreOwner")
  orders       Order[]
  reviews      Review[]
  store_likes  StoreLike[]
  store_picks  StorePick[]

  @@unique([oauth_provider, oauth_subject], map: "users_oauth_provider_oauth_subject_key")
  @@map("users")
}

model Store {
  id         String   @id @default(uuid()) @db.Uuid
  owner_id   String   @db.Uuid
  name       String   @db.VarChar(200)
  location   Unsupported("geometry(Point,4326)")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner      User       @relation("StoreOwner", fields: [owner_id], references: [id], onDelete: Restrict)
  menus      Menu[]
  orders     Order[]
  store_stat StoreStat?
  liked_by   StoreLike[]
  picked_by  StorePick[]

  @@index([owner_id], map: "stores_owner_id_idx")
  @@map("stores")
}

model StoreLike {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  store_id   String   @db.Uuid
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id], map: "store_likes_user_id_store_id_key")
  @@index([store_id], map: "store_likes_store_id_idx")
  @@index([user_id], map: "store_likes_user_id_idx")
  @@map("store_likes")
}

model StorePick {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  store_id   String   @db.Uuid
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id], map: "store_picks_user_id_store_id_key")
  @@index([store_id], map: "store_picks_store_id_idx")
  @@index([user_id], map: "store_picks_user_id_idx")
  @@map("store_picks")
}

model Menu {
  id                   String   @id @default(uuid()) @db.Uuid
  store_id             String   @db.Uuid
  name                 String   @db.VarChar(200)
  reference_image_url  String   @db.VarChar(2048)
  portion_grams        Int?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  store       Store       @relation(fields: [store_id], references: [id], onDelete: Cascade)
  order_items OrderItem[]
  reviews     Review[]

  @@index([store_id], map: "menus_store_id_idx")
  @@map("menus")
}

model Order {
  id                  String   @id @default(uuid()) @db.Uuid
  user_id             String   @db.Uuid
  store_id            String   @db.Uuid
  total_amount        Decimal  @db.Decimal(12, 2)
  currency            String   @db.VarChar(8)
  payment_status      String   @db.VarChar(32)
  external_payment_id String?  @db.VarChar(128)
  created_at          DateTime @default(now())

  user   User        @relation(fields: [user_id], references: [id], onDelete: Restrict)
  store  Store       @relation(fields: [store_id], references: [id], onDelete: Restrict)
  items  OrderItem[]
  reviews Review[]

  @@index([user_id], map: "orders_user_id_idx")
  @@index([store_id], map: "orders_store_id_idx")
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  order_id   String  @db.Uuid
  menu_id    String  @db.Uuid
  quantity   Int
  unit_price Decimal @db.Decimal(12, 2)

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menu_id], references: [id], onDelete: Restrict)

  @@index([order_id], map: "order_items_order_id_idx")
  @@index([menu_id], map: "order_items_menu_id_idx")
  @@map("order_items")
}

model Review {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  order_id     String    @db.Uuid
  menu_id      String    @db.Uuid
  value_score  Decimal?  @db.Decimal(5, 2)
  ai_analysis  Json?
  deleted_at   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user      User                 @relation(fields: [user_id], references: [id], onDelete: Restrict)
  order     Order                @relation(fields: [order_id], references: [id], onDelete: Restrict)
  menu      Menu                 @relation(fields: [menu_id], references: [id], onDelete: Restrict)
  callbacks AiAnalysisCallback[]

  @@index([user_id], map: "reviews_user_id_idx")
  @@index([order_id], map: "reviews_order_id_idx")
  @@index([menu_id], map: "reviews_menu_id_idx")
  @@index([deleted_at], map: "reviews_deleted_at_idx")
  @@map("reviews")
}

model StoreStat {
  store_id          String   @id @db.Uuid
  avg_value_score   Decimal? @db.Decimal(5, 2)
  review_count     Int      @default(0)
  like_count       Int      @default(0)
  pick_count       Int      @default(0)
  ai_summary_line   String?  @db.VarChar(500)
  updated_at        DateTime @updatedAt

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@map("store_stats")
}

model AiAnalysisCallback {
  id                String   @id @default(uuid()) @db.Uuid
  external_job_id   String   @unique @db.VarChar(128)
  review_id         String   @db.Uuid
  status            String   @db.VarChar(32)
  payload           Json
  received_at       DateTime @default(now())

  review Review @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@index([review_id], map: "ai_analysis_callbacks_review_id_idx")
  @@map("ai_analysis_callbacks")
}
