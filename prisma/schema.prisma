generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. User 역할 관리를 위한 Enum 추가
enum UserRole {
  USER
  ADMIN
}

model User {
  id               String      @id @default(uuid()) @db.Uuid
  role             UserRole    @default(USER) // 관리자/일반유저 구분
  oauth_provider   String      @db.VarChar(32)
  oauth_subject    String      @db.VarChar(255)
  email            String?     @db.VarChar(320)
  display_name     String?     @db.VarChar(100)
  region           String?     @db.VarChar(100)
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  orders           Order[]
  reviews          Review[]
  store_likes      StoreLike[]
  store_picks      StorePick[]

  @@unique([oauth_provider, oauth_subject], map: "users_oauth_provider_oauth_subject_key")
  @@map("users")
}

// 1. 가게 사장님(Owner)용 분리된 테이블
model Owner {
  id               String      @id @default(uuid()) @db.Uuid
  oauth_provider   String      @db.VarChar(32)
  oauth_subject    String      @db.VarChar(255)
  email            String?     @db.VarChar(320)
  display_name     String?     @db.VarChar(100)
  phone_number     String?     @db.VarChar(32) // 추후 휴대폰 인증 대비
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  store_details    StoreDetail[]

  @@unique([oauth_provider, oauth_subject], map: "owners_oauth_provider_oauth_subject_key")
  @@map("owners")
}

// Store: 지도/목록용 요약 + 통계 컬럼(구 store_stats 테이블 제거 후 이 테이블에 통합)
model Store {
  place_id         String      @id @db.VarChar(255) // 외부 API(구글맵/TourAPI 등) 고유 ID
  name             String      @db.VarChar(200)
  category         String?     @db.VarChar(100)

  latitude         Decimal?    @db.Decimal(10, 7)
  longitude        Decimal?    @db.Decimal(10, 7)

  // 통계(이전 store_stats → stores 컬럼)
  avg_value_score  Decimal?    @db.Decimal(5, 2)
  review_count     Int         @default(0)
  like_count       Int         @default(0)
  pick_count       Int         @default(0)
  ai_summary_line  String?     @db.VarChar(500)
  
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  detail           StoreDetail?
  menus            Menu[]
  orders           Order[]
  liked_by         StoreLike[]
  picked_by        StorePick[]

  @@map("stores")
}

// StoreDetail: 주소·사장(owner)·영업 정보 등(구 단일 stores 확장 필드는 여기로 분리)
model StoreDetail {
  place_id         String      @id @db.VarChar(255)
  owner_id         String?     @db.Uuid // 외부 API 데이터라 사장님 미등록 상태일 수 있음
  
  address          String?     @db.VarChar(500)
  contact_number   String?     @db.VarChar(50)
  opening_hours    String?     @db.VarChar(500)
  description      String?     @db.Text
  
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  store            Store       @relation(fields: [place_id], references: [place_id], onDelete: Cascade)
  owner            Owner?      @relation(fields: [owner_id], references: [id], onDelete: SetNull)

  @@index([owner_id], map: "store_details_owner_id_idx")
  @@map("store_details")
}

model StoreLike {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  place_id         String   @db.VarChar(255)
  created_at       DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store            Store    @relation(fields: [place_id], references: [place_id], onDelete: Cascade)

  @@unique([user_id, place_id], map: "store_likes_user_id_place_id_key")
  @@index([place_id], map: "store_likes_place_id_idx")
  @@index([user_id], map: "store_likes_user_id_idx")
  @@map("store_likes")
}

model StorePick {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  place_id         String   @db.VarChar(255)
  created_at       DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store            Store    @relation(fields: [place_id], references: [place_id], onDelete: Cascade)

  @@unique([user_id, place_id], map: "store_picks_user_id_place_id_key")
  @@index([place_id], map: "store_picks_place_id_idx")
  @@index([user_id], map: "store_picks_user_id_idx")
  @@map("store_picks")
}

model Menu {
  id                   String      @id @default(uuid()) @db.Uuid
  place_id             String      @db.VarChar(255)
  name                 String      @db.VarChar(200)
  reference_image_url  String      @db.VarChar(2048)
  portion_grams        Int?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  store                Store       @relation(fields: [place_id], references: [place_id], onDelete: Cascade)
  order_items          OrderItem[]
  reviews              Review[]

  @@index([place_id], map: "menus_place_id_idx")
  @@map("menus")
}

model Order {
  id                   String      @id @default(uuid()) @db.Uuid
  user_id              String      @db.Uuid
  place_id             String      @db.VarChar(255)
  total_amount         Decimal     @db.Decimal(12, 2)
  currency             String      @db.VarChar(8)
  payment_status       String      @db.VarChar(32)
  external_payment_id  String?     @db.VarChar(128)
  created_at           DateTime    @default(now())

  user                 User        @relation(fields: [user_id], references: [id], onDelete: Restrict)
  store                Store       @relation(fields: [place_id], references: [place_id], onDelete: Restrict)
  items                OrderItem[]
  reviews              Review[]

  @@index([user_id], map: "orders_user_id_idx")
  @@index([place_id], map: "orders_place_id_idx")
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  order_id     String  @db.Uuid
  menu_id      String  @db.Uuid
  quantity     Int
  unit_price   Decimal @db.Decimal(12, 2)

  order        Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  menu         Menu    @relation(fields: [menu_id], references: [id], onDelete: Restrict)

  @@index([order_id], map: "order_items_order_id_idx")
  @@index([menu_id], map: "order_items_menu_id_idx")
  @@map("order_items")
}

model Review {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  order_id     String    @db.Uuid
  menu_id      String    @db.Uuid
  value_score  Decimal?  @db.Decimal(5, 2)
  ai_analysis  Json?
  deleted_at   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user         User      @relation(fields: [user_id], references: [id], onDelete: Restrict)
  order        Order     @relation(fields: [order_id], references: [id], onDelete: Restrict)
  menu         Menu      @relation(fields: [menu_id], references: [id], onDelete: Restrict)
  callbacks    AiAnalysisCallback[]

  @@index([user_id], map: "reviews_user_id_idx")
  @@index([order_id], map: "reviews_order_id_idx")
  @@index([menu_id], map: "reviews_menu_id_idx")
  @@index([deleted_at], map: "reviews_deleted_at_idx")
  @@map("reviews")
}

model AiAnalysisCallback {
  id               String   @id @default(uuid()) @db.Uuid
  external_job_id  String   @unique @db.VarChar(128)
  review_id        String   @db.Uuid
  status           String   @db.VarChar(32)
  payload          Json
  received_at      DateTime @default(now())

  review           Review   @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@index([review_id], map: "ai_analysis_callbacks_review_id_idx")
  @@map("ai_analysis_callbacks")
}