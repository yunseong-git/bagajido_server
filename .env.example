# PostgreSQL: Supabase 대시보드 → Project Settings → Database → Connection string (URI)
# Prisma migrate 권장: Direct connection(보통 포트 5432). Pooler(6543)는 제약이 있을 수 있음.
# geometry(Point,4326) 사용 시: SQL Editor에서 `CREATE EXTENSION IF NOT EXISTS postgis;` 실행

SESSION_SECRET=change_me_session_secret

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

OAUTH2_AUTHORIZATION_URL=https://example.com/oauth/authorize
OAUTH2_TOKEN_URL=https://example.com/oauth/token
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_CALLBACK_URL=http://localhost:3000/auth/oauth2/callback
OAUTH2_USERINFO_URL=
OAUTH2_SCOPE=openid profile email

RUNPOD_WEBHOOK_SECRET=

PORT=3000
